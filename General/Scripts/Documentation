    { f: 'Receiving Medical Services', o: ['Yes', 'No'] },
    { f: 'Medical Services Type', o: ['Dialysis', 'Wound Care', 'Other'] },

    { f: 'Vision or Hearing Concerns', o: ['Yes', 'No'] },
    { f: 'Dental Care / Other Notes', o: null, n: 'Free text' },

    { f: 'Previously Scheduled Appointments', o: ['Yes', 'No'] },
    { f: 'Appointment Details', o: null, n: 'Free text' },

