  let currentOptRow = 2;
  const intakeRows = [];
  const optRows = [['Field', 'Option']];

  FIELD_DEFS.forEach((def, i) => {
    const isMulti = CONFIG.multiSelectFields.has(def.f);
    intakeRows.push([def.f, '', isMulti ? 'Multi-select' : (def.n || '')]);

    if (def.o) {
      const options = def.o.slice();
      if (isMulti && !options.includes('N/A')) options.push('N/A');

      const start = currentOptRow;
      options.forEach(opt => {
        optRows.push([def.f, opt]);
        currentOptRow++;
      });

      const validationRange = optionsSheet.getRange(start, 2, options.length, 1);
      const rule = SpreadsheetApp.newDataValidation()
        .requireValueInRange(validationRange)
        .setAllowInvalid(true)
        .build();

      intake.getRange(i + 2, 2).setDataValidation(rule);
    }
  });

