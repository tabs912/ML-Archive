      'Med Buddy': 'Med Buddy',
      'Other': 'an alternate medication system'
    }
  };

  if (maps[field] && maps[field][v] !== undefined) return maps[field][v];

  const preserve = ['HOPE', 'CPAP', 'O2', 'ADA', 'HHSH', 'POV', '4WW', 'FWW', 'SPC', 'MOW'];
  if (preserve.includes(v)) return v;
  if (/^[A-Z0-9]+$/.test(v)) return v;

  return v.toLowerCase();
