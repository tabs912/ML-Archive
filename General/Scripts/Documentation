/*************************************************
 * HOME SAFETY INTAKE - MASTER INTEGRATED SCRIPT
 * Version: 8.1
 * - Builds intake form with dropdowns
 * - Supports mobile-friendly multi-select
 * - Generates standardized clinical narrative
 * - Implements latest Column D corrections
 *************************************************/

const CONFIG = {
  intakeSheetName: 'Home Safety Intake',
  optionsSheetName: '_Options',
  outputName: 'Generated Note',
  fieldCol: 1,      // Column A
  responseCol: 2,   // Column B
  detailsCol: 3,    // Column C
  firstDataRow: 2,
  delimiter: ', ',

  multiSelectFields: new Set([
    'Source of Information for Assessment',
    'Infestation Concerns',
    'Overall Condition',
    'Pathways',
    'Tripping Hazard Types',
    'Appliances Not Working',
    'Bathroom DME in Use',
    'Bathroom DME Recommended',
    'Who Provides ADL Assistance',
    'Community Services',
    'Type of Supplies',
    'Medical Services Type',
    'Safety Concerns Identified',
    'ADL Assistance Needed',
    'IADL Assistance Needed',
    'DME Details',
    'Additional DME Recommended Details',
    'Clothing Storage Locations'
  ])
};

/* =========================
 * MENU
 * ========================= */
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('Home Safety Tools')
    .addItem('Build / Refresh Sheet', 'setupHomeSafetySheet')
    .addItem('Generate Narrative Note', 'generateNarrative')
    .addToUi();
}

/* =========================
 * BUILD SHEET
 * ========================= */
