function enforceGlobalSheetSortOrder_(monthParts) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const currentParts = monthParts || getMonthDateParts_(new Date());
  const currentFirst = currentParts && currentParts.firstDay ? currentParts.firstDay : null;

  function name_(sheet) {
    return String(sheet.getName() || "").trim();
  }

  function isTemplate_(sheetName) {
    return sheetName === RFF_BASE_TEMPLATE_NAME || sheetName.indexOf("Template") !== -1;
  }

  function rank_(sheet) {
    const sheetName = name_(sheet);
    if (sheetName === INDEX_SHEET) return 10;
    if (sheetName.indexOf(DEMO_P_PREFIX) === 0) return 20;
    if (sheetName.indexOf(MONTHLY_CHANGE_REPORT_PREFIX) === 0) return 30;
    if (sheetName.indexOf(MASTER_LIST_PREFIX) === 0) return 40;
    if (sheetName === DISENROLLED_EXCLUSION_SHEET || sheetName.indexOf("Disenrolled") !== -1) return 50;
    if (sheetName === RFF_TEST_DASHBOARD_SHEET || sheetName === "Dashboard Quality Report") return 60;
    if (sheetName === RFF_TIMING_SHEET || sheetName === "Framework Timing Report") return 70;
    if (sheetName === RFF_DASHBOARD_SHEET) return 80;
    if (sheetName.indexOf("Raw Data") === 0) return 90;
    if (sheetName.indexOf(BANNER_PREFIX) === 0 || sheetName.indexOf(BANNER_REPORT_ALT_PREFIX) === 0) return 100;
    if (sheetName.indexOf(UNLOCKED_PREFIX) === 0 || sheetName.indexOf("Unlocked Care Plan") === 0) return 110;
    if (sheetName.indexOf(CARE_PLAN_DUE_PREFIX) === 0 || sheetName.indexOf(CARE_PLAN_DUE_DATE_ALT_PREFIX) === 0) return 120;
    if (isTemplate_(sheetName)) return 900;
    return 500;
  }

  function dateRank_(sheet) {
    const date = extractFirstDateFromSheetName_(name_(sheet));
    if (!date) return 0;
    if (currentFirst && date.getTime() === currentFirst.getTime()) return -9999999999999;
    return -date.getTime();
  }

  const orderedSheets = ss.getSheets().slice().sort(function(a, b) {
    const rankDiff = rank_(a) - rank_(b);
    if (rankDiff !== 0) return rankDiff;
    const dateDiff = dateRank_(a) - dateRank_(b);
    if (dateDiff !== 0) return dateDiff;
    return name_(a).localeCompare(name_(b));
  });

  const currentOrderNames = ss.getSheets().map(name_).join("|");
  const desiredOrderNames = orderedSheets.map(name_).join("|");
  if (currentOrderNames === desiredOrderNames) return 0;

  let position = 1;
  let moves = 0;
  orderedSheets.forEach(function(sheet) {
    try {
      const wasHidden = typeof sheet.isSheetHidden === "function" && sheet.isSheetHidden();
      if (wasHidden) sheet.showSheet();
      if (sheet.getIndex() !== position) {
        ss.setActiveSheet(sheet);
        ss.moveActiveSheet(position);
        moves++;
      }
      position++;
      const inferredType = inferSheetTypeFromName_(name_(sheet));
      if (inferredType) applyOutputVisibilityPolicy_(sheet, loadDashboardConfig_(), inferredType, null);
      if (((wasHidden && !inferredType) || isTemplate_(name_(sheet)) || name_(sheet) === RFF_BASE_TEMPLATE_NAME) && !sheet.isSheetHidden()) {
        sheet.hideSheet();
      }
    } catch (err) {
      Logger.log("Global sheet sort skipped for " + name_(sheet) + ": " + err.message);
    }
  });
  return moves;
}

function extractFirstDateFromSheetName_(sheetName) {
  const text = String(sheetName || "").trim();
  const match = text.match(/(\d{1,2})\.(\d{1,2})\.(\d{2}|\d{4})/);
  if (!match) return null;
  const month = Number(match[1]);
  const day = Number(match[2]);
  let year = Number(match[3]);
  if (year < 100) year += 2000;
  const date = createLocalDateOnly_(year, month - 1, day);
  if (
    date.getFullYear() !== year ||
    date.getMonth() !== month - 1 ||
    date.getDate() !== day
  ) {
    return null;
  }
  return date;
}

function parseIndexMonthDate_(value) {
  if (value instanceof Date && !isNaN(value.getTime())) {
    return createLocalDateOnly_(value.getFullYear(), value.getMonth(), value.getDate());
  }
  const text = String(value || "").trim();
  if (!text) return null;
  const dotMatch = text.match(/^(\d{1,2})\.(\d{1,2})\.(\d{2}|\d{4})$/);
  if (dotMatch) {
    const month = Number(dotMatch[1]);
    const day = Number(dotMatch[2]);
    let year = Number(dotMatch[3]);
    if (year < 100) year += 2000;
    const date = createLocalDateOnly_(year, month - 1, day);
    if (
      date.getFullYear() === year &&
      date.getMonth() === month - 1 &&
      date.getDate() === day
    ) {
      return date;
    }
  }
  return coerceToValidDate_(text);
}

