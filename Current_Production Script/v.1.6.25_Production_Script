function updateDemoPMonthlySync() {
  const monthParts = promptForLockedYearReportMonth_("Update Demo P (Monthly Change Sync)");
  if (!monthParts) return null;
  const timing = startRuntimeTiming_("Update Demo P (Monthly Change Sync)", monthParts);
  try {
    const demoSheet = getCurrentDemoPSheet_(monthParts);
    if (!demoSheet) throw new Error("Ongoing Demo P sheet was not found. Run Build Demo P (Initialization) first.");
    markRuntimeStep_(timing, "Locate ongoing Demo P sheet");

    const changedPMRs = getDemoPMonthlySyncChangedPMRs_(monthParts);
    markRuntimeStep_(timing, "Monthly Change PMRs loaded for Demo P sync | PMRs: " + changedPMRs.size);

    const data = getDataValues_(demoSheet, HEADER_ROW, DATA_START_ROW);
    const keptRows = processDemoPDataWithFillBlankMask_(data, changedPMRs);
    markRuntimeStep_(timing, "Existing Demo P rows processed with fill-blanks-only mask");

    const rawSheet = getCurrentRawDataSheet_(monthParts);
    const freshRows = rawSheet ? buildDemoPFreshRowsForPMRs_(rawSheet, data.headers, changedPMRs, monthParts, timing) : [];
    markRuntimeStep_(timing, "Fresh Raw Data rows mapped for changed Demo P PMRs | Rows: " + freshRows.length);

    const finalRows = keptRows.concat(freshRows);
    sortDemoPFlatRows_(finalRows, data.headerMap);
    if (data.range) data.range.clearContent();
    if (finalRows.length) {
      demoSheet.getRange(DATA_START_ROW, 1, finalRows.length, data.headers.length).setValues(finalRows);
    }
    const flatCount = flattenDemoPContactsToPrimaryRows_(demoSheet, false);
    enforceDemoPPostFlattenFormatting_(demoSheet);
    markRuntimeStep_(timing, "Demo P monthly flat-record sync written | Rows retained: " + flatCount);
    writeRuntimeTimingReport_(timing);
    notify_("Update Demo P (Monthly Change Sync) complete. PMRs reviewed: " + changedPMRs.size);
    return demoSheet;
  } catch (err) {
    markRuntimeStep_(timing, "ERROR - " + err.message);
    writeRuntimeTimingReport_(timing);
    notifyErrorWithTiming_("Update Demo P (Monthly Change Sync) stopped: " + err.message);
    throw err;
  }
}

function enforceDemoPPostFlattenFormatting_(demoSheet) {
  if (!demoSheet) return;
