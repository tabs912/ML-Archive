function compareRawDemoPForSectionReport_(previousDemo, currentDemo, monthParts) {
  const previousData = getRawDemoPDataForCompare_(previousDemo);
  const currentData = getRawDemoPDataForCompare_(currentDemo);


  const enrollmentPMRs = new Set();
  const disenrollmentPMRs = new Set();
  const demographicPMRs = new Set();
  const caseloadPMRs = new Set();
  const contactPMRs = new Set();
  const bannerPMRs = new Set();


  const demographicChangedColumnsByPMR = new Map();
  const caseloadChangedColumnsByPMR = new Map();
  const contactChangedColumnsByPMR = new Map();
  const bannerChangedColumnsByPMR = new Map();


  currentData.rowsByPMR.forEach((currentRows, pmr) => {
    const previousRows = previousData.rowsByPMR.get(pmr) || [];


    const capitationHeader = "Capitation Date";
    const disenrollEffectiveHeader = "Disenrollment Effective Date";


    const mostRecentCapitationDate = getMostRecentDateFromRowsByHeader_(
      currentRows,
      currentData.headerMap,
      capitationHeader
    );


    const isEnrollmentPMR = isSameDate_(mostRecentCapitationDate, monthParts.firstDay);


    const isDisenrollmentPMR =
      currentRows.some(item => {
        const effectiveDate = getFieldValueFromRow_(
          item.values,
          currentData.headerMap,
          disenrollEffectiveHeader
        );


        return isSameDate_(effectiveDate, monthParts.firstDay);
      });


    if (isEnrollmentPMR) enrollmentPMRs.add(pmr);
    if (isDisenrollmentPMR) disenrollmentPMRs.add(pmr);


    if (isEnrollmentPMR || isDisenrollmentPMR) return;


    if (isParticipantEnrollmentStatusDisenrolled_(currentRows, currentData.headerMap)) return;


    const currentDobRows = rowsWithDOBOnlyForSection_(currentRows, currentData.headerMap);
    const previousDobRows = rowsWithDOBOnlyForSection_(previousRows, previousData.headerMap);


    const demographicChangedColumns = getChangedColumnsForSectionRows_(
      currentDobRows,
      previousDobRows,
      currentData.headers,
      previousData.headers,
      RAW_DEMO_P_DEMOGRAPHIC_FIELDS,
      currentData.headerMap,
      previousData.headerMap
    );


    if (demographicChangedColumns.size > 0) {
      demographicPMRs.add(pmr);
      demographicChangedColumnsByPMR.set(pmr, demographicChangedColumns);
    }


    const caseloadChangedColumns = getChangedColumnsForSectionRows_(
      currentDobRows,
      previousDobRows,
      currentData.headers,
      previousData.headers,
      RAW_DEMO_P_CASELOAD_FIELDS,
      currentData.headerMap,
      previousData.headerMap
    );


    if (caseloadChangedColumns.size > 0) {
      caseloadPMRs.add(pmr);
      caseloadChangedColumnsByPMR.set(pmr, caseloadChangedColumns);
    }


    const contactChangedColumns = getChangedColumnsForSectionRows_(
      currentRows,
      previousRows,
      currentData.headers,
      previousData.headers,
      RAW_DEMO_P_CONTACT_FIELDS,
      currentData.headerMap,
      previousData.headerMap
    );


    if (contactChangedColumns.size > 0) {
      contactPMRs.add(pmr);
      contactChangedColumnsByPMR.set(pmr, contactChangedColumns);
    }


    const bannerChangedColumns = getChangedColumnsForSectionRows_(
      currentRows,
      previousRows,
      currentData.headers,
      previousData.headers,
      RAW_DEMO_P_BANNER_FIELDS,
      currentData.headerMap,
      previousData.headerMap
    );


    if (bannerChangedColumns.size > 0) {
      bannerPMRs.add(pmr);
      bannerChangedColumnsByPMR.set(pmr, bannerChangedColumns);
    }
  });


  enrollmentPMRs.forEach(pmr => {
    demographicPMRs.delete(pmr);
    caseloadPMRs.delete(pmr);
    contactPMRs.delete(pmr);
    bannerPMRs.delete(pmr);
  });


  disenrollmentPMRs.forEach(pmr => {
    demographicPMRs.delete(pmr);
    caseloadPMRs.delete(pmr);
    contactPMRs.delete(pmr);
    bannerPMRs.delete(pmr);
  });


  return {
    previousData: previousData,
    currentData: currentData,
    enrollmentPMRs: enrollmentPMRs,
    disenrollmentPMRs: disenrollmentPMRs,
    demographicPMRs: demographicPMRs,
    caseloadPMRs: caseloadPMRs,
    contactPMRs: contactPMRs,
    bannerPMRs: bannerPMRs,
    demographicChangedColumnsByPMR: demographicChangedColumnsByPMR,
    caseloadChangedColumnsByPMR: caseloadChangedColumnsByPMR,
    contactChangedColumnsByPMR: contactChangedColumnsByPMR,
    bannerChangedColumnsByPMR: bannerChangedColumnsByPMR
  };
}

function rowsWithDOBOnlyForSection_(items, headerMap) {
  const dobIdx = getDOBIndex_(headerMap);
  if (dobIdx === -1) return [];
  return (items || []).filter(item => normalizeCompareValue_(item.values[dobIdx]) !== "");
}

function getChangedColumnsForSectionRows_(currentItems, previousItems, currentHeaders, previousHeaders, columnsToCompare, currentHeaderMap, previousHeaderMap) {
  const changed = new Set();


  if (!currentItems || currentItems.length === 0) return changed;


  if (!previousItems || previousItems.length === 0) return changed;


  columnsToCompare.forEach(header => {


    if (currentHeaderMap[header] === undefined || previousHeaderMap[header] === undefined) return;


    const currentSig = buildColumnSignatureForSection_(currentItems, currentHeaderMap, [header]);
    const previousSig = buildColumnSignatureForSection_(previousItems, previousHeaderMap, [header]);


    if (currentSig !== previousSig) changed.add(header);
  });


  return changed;
}

function buildColumnSignatureForSection_(items, headerMap, columnsToCompare) {
  return (items || [])
    .map(item => {
      return columnsToCompare.map(header => {
        const idx = headerMap[header];
        if (idx === undefined || idx === -1) return "";
        return normalizeCompareValue_(item.values[idx]);
      }).join("~");
    })
    .sort()
    .join("||");
}

function compareRawDemoPForChanges_(previousDemo, currentDemo, monthParts) {
  const previousData = getRawDemoPDataForCompare_(previousDemo);
  const currentData = getRawDemoPDataForCompare_(currentDemo);


  const outputRows = [];
  const changedPMRs = new Map();


  currentData.participantRows.forEach((currentMain, pmr) => {
    const previousMain = previousData.participantRows.get(pmr);


    const capitationIdx = currentData.headerMap["Capitation Date"];
    const currentCapitation = capitationIdx !== undefined ? currentMain.values[capitationIdx] : "";


    const isNewPMR = !previousData.allPMRs.has(pmr);
    const isReportMonthCapitation = isSameMonth_(currentCapitation, monthParts.firstDay);


    if (isNewPMR || isReportMonthCapitation) {
      RAW_DEMO_P_ENROLLMENT_FIELDS.forEach(field => {
        const currentValue = getFieldValueFromRow_(currentMain.values, currentData.headerMap, field);
        if (normalizeCompareValue_(currentValue) !== "") {
          addMCRRow_(
            outputRows,
            changedPMRs,
            CHANGE_SECTION_ENROLLMENTS,
            pmr,
            currentMain,
            null,
            currentData,
            previousData,
            field,
            "",
            currentValue,
            monthParts
          );
        }
      });
    }
  });


  currentData.participantRows.forEach((currentMain, pmr) => {
    const effective = getFieldValueFromRow_(currentMain.values, currentData.headerMap, "Disenrollment Effective Date");
    const disenrollDate = getFieldValueFromRow_(currentMain.values, currentData.headerMap, "Disenrollment Date");
    const deathDate = getFieldValueFromRow_(currentMain.values, currentData.headerMap, "Date of Death");


    const isCurrentEffective = isSameDate_(effective, monthParts.firstDay);
    const isPriorMonthDisenroll = isSameMonth_(disenrollDate, monthParts.previousMonthFirstDay);
    const isPriorMonthDeath = isSameMonth_(deathDate, monthParts.previousMonthFirstDay);


    if (isCurrentEffective || isPriorMonthDisenroll || isPriorMonthDeath) {
      RAW_DEMO_P_DISENROLLMENT_FIELDS.forEach(field => {
        const currentValue = getFieldValueFromRow_(currentMain.values, currentData.headerMap, field);
        if (normalizeCompareValue_(currentValue) !== "") {
          addMCRRow_(
            outputRows,
            changedPMRs,
            CHANGE_SECTION_DISENROLLMENTS,
            pmr,
            currentMain,
            null,
            currentData,
            previousData,
            field,
            "",
            currentValue,
            monthParts
          );
        }
      });
    }
  });


  currentData.participantRows.forEach((currentMain, pmr) => {
    const previousMain = previousData.participantRows.get(pmr);
    if (!previousMain) return;


    RAW_DEMO_P_DEMOGRAPHIC_FIELDS.forEach(field => {
      compareSingleFieldAndAdd_(
        outputRows,
        changedPMRs,
        CHANGE_SECTION_DEMOGRAPHIC,
        pmr,
        previousMain,
        currentMain,
        previousData,
        currentData,
        field,
        monthParts,
        true
      );
    });


    RAW_DEMO_P_CASELOAD_FIELDS.forEach(field => {
      compareSingleFieldAndAdd_(
        outputRows,
        changedPMRs,
        CHANGE_SECTION_CASELOAD,
        pmr,
        previousMain,
        currentMain,
        previousData,
        currentData,
        field,
        monthParts,
        true
      );
    });
  });


  const allCurrentPMRs = Array.from(currentData.allPMRs);
  allCurrentPMRs.forEach(pmr => {
    if (!previousData.allPMRs.has(pmr)) return;


    const previousRows = previousData.rowsByPMR.get(pmr) || [];
    const currentRows = currentData.rowsByPMR.get(pmr) || [];


    const maxLength = Math.max(previousRows.length, currentRows.length);


    for (let i = 0; i < maxLength; i++) {
      const previousItem = previousRows[i] || null;
      const currentItem = currentRows[i] || null;


      RAW_DEMO_P_CONTACT_FIELDS.forEach(field => {
        const previousValue = previousItem ? getFieldValueFromRow_(previousItem.values, previousData.headerMap, field) : "";
        const currentValue = currentItem ? getFieldValueFromRow_(currentItem.values, currentData.headerMap, field) : "";


        if (!valuesAreEqual_(previousValue, currentValue)) {
          addMCRRow_(
            outputRows,
            changedPMRs,
            CHANGE_SECTION_CONTACT,
            pmr,
            currentItem,
            previousItem,
            currentData,
            previousData,
            field,
            previousValue,
            currentValue,
            monthParts
          );
        }
      });
    }
  });


  return {
    rows: outputRows,
    changedPMRs: changedPMRs
  };
}

function getRawDemoPDataForCompare_(sheet) {
  const data = getDataValues_(sheet, HEADER_ROW, DATA_START_ROW);


  const headers = data.headers;
  const headerMap = data.headerMap;
  const pmrIdx = getPMRIndex_(headerMap);
  const dobIdx = getDOBIndex_(headerMap);


  if (pmrIdx === -1) {
    throw new Error(`${sheet.getName()} is missing Participant PMR# / PMR # column.`);
  }


  const values = data.values;


  const rowsByPMR = new Map();
  const participantRows = new Map();
  const allPMRs = new Set();


  values.forEach((row, idx) => {
    const pmr = normalizePMR_(row[pmrIdx]);
    if (!pmr) return;


    allPMRs.add(pmr);


    const item = {
      rowNumber: DATA_START_ROW + idx,
      values: row
    };


    if (!rowsByPMR.has(pmr)) rowsByPMR.set(pmr, []);
    rowsByPMR.get(pmr).push(item);


    if (!participantRows.has(pmr)) {
      if (dobIdx === -1 || normalizeCompareValue_(row[dobIdx]) !== "") {
        participantRows.set(pmr, item);
      }
    }
  });


  rowsByPMR.forEach((items, pmr) => {
    if (!participantRows.has(pmr) && items.length > 0) {
      participantRows.set(pmr, items[0]);
    }
  });


  return {
    sheet: sheet,
    sheetName: sheet.getName(),
    headers: headers,
    headerMap: headerMap,
    values: values,
    rowsByPMR: rowsByPMR,
    participantRows: participantRows,
    allPMRs: allPMRs
  };
}

function compareSingleFieldAndAdd_(
  outputRows,
  changedPMRs,
  section,
  pmr,
  previousItem,
  currentItem,
  previousData,
  currentData,
  field,
  monthParts,
  skipIfCurrentDOBBlank
) {
  if (!previousItem || !currentItem) return;


  if (skipIfCurrentDOBBlank) {
    const currentDOBIdx = getDOBIndex_(currentData.headerMap);
    if (currentDOBIdx !== -1 && normalizeCompareValue_(currentItem.values[currentDOBIdx]) === "") return;
  }


  if (field !== "Participant PMR#" && currentData.headerMap[field] === undefined && previousData.headerMap[field] === undefined) {
    return;
  }


  const previousValue = getFieldValueFromRow_(previousItem.values, previousData.headerMap, field);
  const currentValue = getFieldValueFromRow_(currentItem.values, currentData.headerMap, field);


  if (!valuesAreEqual_(previousValue, currentValue)) {
    addMCRRow_(
      outputRows,
      changedPMRs,
      section,
      pmr,
      currentItem,
      previousItem,
      currentData,
      previousData,
      field,
      previousValue,
      currentValue,
      monthParts
    );
  }
}

function addMCRRow_(
  outputRows,
  changedPMRs,
  section,
  pmr,
  currentItem,
  previousItem,
  currentData,
  previousData,
  field,
  previousValue,
  currentValue,
  monthParts
) {
  const mainItem = currentItem || previousItem;
  const currentValues = currentItem ? currentItem.values : (mainItem ? mainItem.values : []);
  const currentMap = currentData.headerMap;


  const lastName = getFieldValueFromRow_(currentValues, currentMap, "Last Name");
  const firstName = getFieldValueFromRow_(currentValues, currentMap, "First Name");
  const participantName = buildParticipantName_(currentValues, currentMap);


  outputRows.push([
    section,
    pmr,
    participantName,
    lastName,
    firstName,
    field,
    displayValueForReport_(previousValue),
    displayValueForReport_(currentValue),
    previousItem ? previousItem.rowNumber : "",
    currentItem ? currentItem.rowNumber : "",
    monthParts.firstDay
  ]);


  if (!changedPMRs.has(pmr)) changedPMRs.set(pmr, new Set());
  changedPMRs.get(pmr).add(section);
}

function getFieldValueFromRow_(row, headerMap, field) {
  const idx = headerMap[field];
  if (idx === undefined || idx < 0) return "";
  return row[idx];
}

function buildParticipantName_(row, headerMap) {
  const participantName = getFieldValueFromRow_(row, headerMap, "Participant Name");
  if (normalizeCompareValue_(participantName) !== "") return participantName;


  const last = getFieldValueFromRow_(row, headerMap, "Last Name");
  const first = getFieldValueFromRow_(row, headerMap, "First Name");


  const lastText = String(last || "").trim();
  const firstText = String(first || "").trim();


  if (firstText && lastText) return `${firstText} ${lastText}`;
  return firstText || lastText || "";
}

function displayValueForReport_(value) {
  if (value instanceof Date && !isNaN(value.getTime())) {
    return formatDateDisplay_(value);
  }
  return value === null || value === undefined ? "" : String(value);
}


function buildMonthlyChangeReportSectionLayout_(reportSheet, sourceSheet, headers, monthParts) {
  const reportHeaders = getMonthlyChangeReportHeaders_(headers || []);
  const lastCol = Math.max(reportHeaders.length, 1);

  stripMonthlyChangeNativeBandings_(reportSheet);
  resizeSheetGrid_(reportSheet, Math.max(reportSheet.getMaxRows(), 10), lastCol);

  // Preserve governed top-of-report metadata from the copied Monthly Change template.
  reportSheet.getRange("A1").setValue("Monthly Change Report");
  reportSheet.getRange("A2").setValue("Date");
  if (monthParts) {
    reportSheet.getRange("B2").setValue(monthParts.firstDay);
    reportSheet.getRange("C2").setValue("to");
    reportSheet.getRange("D2").setValue(monthParts.lastDay);
  }
  if (reportHeaders.length) {
    reportSheet.getRange(HEADER_ROW, 1, 1, lastCol).setValues([padRowToWidth_(reportHeaders, lastCol)]);
  }

  reportSheet.setFrozenRows(4);
  reportSheet.setFrozenColumns(2);
}


function padRowToWidth_(rowValues, width) {
  const output = (rowValues || []).slice(0, width);
  while (output.length < width) output.push("");
  return output;
}

function stripMonthlyChangeNativeBandings_(reportSheet) {
  if (!reportSheet) return;
  const bandings = reportSheet.getBandings();
  if (bandings && bandings.length) {
    bandings.forEach(function(banding) {
      banding.remove();
    });
  }
}

function getMonthlyChangeSectionSpecs_(sectionData) {
  return [
    {
      title: "Enrollments",
      pmrSet: sectionData.enrollmentPMRs,
      rowMode: "dobOnly",
      changedColumnsByPMR: new Map()
    },
    {
      title: "Disenrollments",
      pmrSet: sectionData.disenrollmentPMRs,
      rowMode: "strictDisenrollmentEffectiveDate",
      changedColumnsByPMR: new Map()
    },
    {
      title: "Demographic Changes",
      pmrSet: sectionData.demographicPMRs,
      rowMode: "dobOnly",
      changedColumnsByPMR: sectionData.demographicChangedColumnsByPMR
    },
    {
      title: "Caseload Changes",
      pmrSet: sectionData.caseloadPMRs,
      rowMode: "dobOnly",
      changedColumnsByPMR: sectionData.caseloadChangedColumnsByPMR
    },
    {
      title: "Contact Changes",
      pmrSet: sectionData.contactPMRs,
      rowMode: "allRows",
      changedColumnsByPMR: sectionData.contactChangedColumnsByPMR
    },
    {
      title: "Banner Summary Changes",
      pmrSet: sectionData.bannerPMRs,
      rowMode: "allRows",
      changedColumnsByPMR: sectionData.bannerChangedColumnsByPMR
    }
  ];
}

function buildMonthlyChangeSectionRows_(currentData, pmrSet, sectionTitle, rowMode, changedColumnsByPMR, monthParts) {
  if (!currentData || !pmrSet || pmrSet.size === 0) return [];

  const reportHeaders = getMonthlyChangeReportHeaders_(currentData.headers || []);
  const dobIdx = getDOBIndex_(currentData.headerMap || {});
  const disenrollEffectiveIdx = findHeaderIndex_(currentData.headerMap || {}, ["Disenrollment Effective Date", "Disenrollment Date"]);
  const pmrIdx = getPMRIndex_(currentData.headerMap || {});
  const allowDuplicateRowsForPMR = sectionTitle === "Contact Changes" || sectionTitle === "Banner Summary Changes";
  const rowsToInsert = [];

  Array.from(pmrSet).sort().forEach(function(pmr) {
    const items = currentData.rowsByPMR.get(pmr) || [];
    let insertedForThisPMR = false;
    items.forEach(function(item) {
      if (!allowDuplicateRowsForPMR && insertedForThisPMR) return;
      if (rowMode === "dobOnly" && (dobIdx === -1 || normalizeCompareValue_(item.values[dobIdx]) === "")) return;
      if (rowMode === "strictDisenrollmentEffectiveDate") {
        if (disenrollEffectiveIdx === -1 || !monthParts) return;
        const effectiveDate = item.values[disenrollEffectiveIdx];
        if (!isSameDate_(effectiveDate, monthParts.firstDay)) return;
      }
      if (rowMode === "disenrollmentEffectiveRange") {
        if (disenrollEffectiveIdx === -1 || !monthParts) return;
        const effectiveDate = item.values[disenrollEffectiveIdx];
        if (!isDateInStrictLocalRangeInclusive_(effectiveDate, monthParts.previousMonthFirstDay, monthParts.firstDay)) return;
      }
      const changedColumns = changedColumnsByPMR && changedColumnsByPMR.has(pmr) ? changedColumnsByPMR.get(pmr) : new Set();
      rowsToInsert.push({
        values: buildMonthlyChangeReportRow_(item.values, currentData.headers, reportHeaders, changedColumns),
        changedColumns: changedColumns
      });
      if (!allowDuplicateRowsForPMR) insertedForThisPMR = true;
    });
  });

  if (sectionTitle === "Disenrollments" && disenrollEffectiveIdx !== -1 && pmrIdx !== -1) {
    rowsToInsert.sort(function(a, b) {
      const dateA = a.values[disenrollEffectiveIdx] ? new Date(a.values[disenrollEffectiveIdx]) : new Date(0);
      const dateB = b.values[disenrollEffectiveIdx] ? new Date(b.values[disenrollEffectiveIdx]) : new Date(0);
      return dateB - dateA;
    });
  }

  return rowsToInsert;
}

function appendMonthlyChangeCompiledRow_(matrix, rowValues, backgroundColor, fontWeight, fontSize, lastCol) {
  matrix.values.push(padRowToWidth_(rowValues || [], lastCol));
  matrix.backgrounds.push(new Array(lastCol).fill(backgroundColor || "#FFFFFF"));
  matrix.fontWeights.push(new Array(lastCol).fill(fontWeight || "normal"));
  matrix.fontSizes.push(new Array(lastCol).fill(fontSize || 10));
  matrix.fontColors.push(new Array(lastCol).fill("#000000"));
}

function appendMonthlyChangeSectionBlock_(matrix, spec, dataRows, reportHeaders, theme, lastCol, globals) {
  globals = globals || {};
  const titleFontSize = Number(globals.titleFontSize || 14);
  const standardFontSize = Number(globals.standardFontSize || 10);
  const sectionTitleRow = new Array(lastCol).fill("");
  sectionTitleRow[0] = spec.title;
  appendMonthlyChangeCompiledRow_(matrix, sectionTitleRow, theme.level3, "bold", titleFontSize, lastCol);
  appendMonthlyChangeCompiledRow_(matrix, [], theme.level1, "normal", standardFontSize, lastCol);
  appendMonthlyChangeCompiledRow_(matrix, reportHeaders, theme.level2, "bold", standardFontSize, lastCol);
  appendMonthlyChangeCompiledRow_(matrix, [], "#FFFFFF", "normal", standardFontSize, lastCol);

  const activeRows = dataRows && dataRows.length ? dataRows : [{ values: new Array(lastCol).fill(""), changedColumns: new Set() }];
  activeRows.forEach(function(rowInfo) {
    const row = padRowToWidth_(rowInfo.values || [], lastCol);
    const backgrounds = new Array(lastCol).fill("#FFFFFF");
    if (rowInfo.changedColumns && rowInfo.changedColumns.size > 0) {
      reportHeaders.forEach(function(header, index) {
        if (rowInfo.changedColumns.has(header)) backgrounds[index] = "#f3ffc7";
      });
    }
    matrix.values.push(row);
    matrix.backgrounds.push(backgrounds);
    matrix.fontWeights.push(new Array(lastCol).fill("normal"));
    matrix.fontSizes.push(new Array(lastCol).fill(standardFontSize));
    matrix.fontColors.push(new Array(lastCol).fill("#000000"));
  });

  appendMonthlyChangeCompiledRow_(matrix, [], "#FFFFFF", "normal", standardFontSize, lastCol);
}

function populateMonthlyChangeReportSections_(reportSheet, sectionData, monthParts) {
  if (!reportSheet || !sectionData || !sectionData.currentData) return;

  const dashboard = loadDashboardConfig_();
  const globals = dashboard.globals || {};
  const sheetDef = getSheetDefinitionByType_(dashboard, SHEET_TYPE.MONTHLY_CHANGE);
  const currentData = sectionData.currentData;
  const reportHeaders = getMonthlyChangeReportHeaders_(currentData.headers || []);
  const lastCol = Math.max(reportHeaders.length, 1);
  const theme = getThemeColorsFromBase_((sheetDef && sheetDef.baseColor) || "#A165CC", globals);
  const matrix = {
    values: [],
    backgrounds: [],
    fontWeights: [],
    fontSizes: [],
    fontColors: []
  };

  getMonthlyChangeSectionSpecs_(sectionData).forEach(function(spec) {
    const dataRows = buildMonthlyChangeSectionRows_(
      currentData,
      spec.pmrSet,
      spec.title,
      spec.rowMode,
      spec.changedColumnsByPMR,
      monthParts
    );
    appendMonthlyChangeSectionBlock_(matrix, spec, dataRows, reportHeaders, theme, lastCol, globals);
  });

  stripMonthlyChangeNativeBandings_(reportSheet);
  const requiredRows = Math.max(HEADER_ROW + matrix.values.length, 1);
  resizeSheetGrid_(reportSheet, requiredRows, lastCol);

  const existingRows = Math.max(reportSheet.getMaxRows() - HEADER_ROW, matrix.values.length, 1);
  reportSheet.getRange(HEADER_ROW + 1, 1, existingRows, lastCol).clear();

  if (matrix.values.length > 0) {
    const targetRange = reportSheet.getRange(HEADER_ROW + 1, 1, matrix.values.length, lastCol);
    targetRange
      .setValues(matrix.values)
      .setBackgrounds(matrix.backgrounds)
      .setFontWeights(matrix.fontWeights)
      .setFontSizes(matrix.fontSizes)
      .setFontColors(matrix.fontColors)
      .setHorizontalAlignment("left")
      .setVerticalAlignment("middle")
      .setWrapStrategy(SpreadsheetApp.WrapStrategy.CLIP);
    reportSheet.getRange(1, 1, Math.max(reportSheet.getMaxRows(), 1), 1)
      .setWrapStrategy(SpreadsheetApp.WrapStrategy.OVERFLOW);
  }
}

function findMonthlyChangeSectionTitleRow_(sheet, title) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 1) return -1;


  const values = sheet.getRange(1, 1, lastRow, 1).getValues();


  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || "").trim() === title) return i + 1;
  }


  return -1;
}

function findNextMonthlyChangeSectionTitleRow_(sheet, afterRow) {
  const titles = new Set(["Enrollments", "Disenrollments", "Demographic Changes", "Caseload Changes", "Contact Changes", "Banner Summary Changes"]);
  const lastRow = sheet.getLastRow();


  if (afterRow >= lastRow) return -1;


  const values = sheet.getRange(afterRow + 1, 1, lastRow - afterRow, 1).getValues();


  for (let i = 0; i < values.length; i++) {
    const value = String(values[i][0] || "").trim();
    if (titles.has(value)) return afterRow + 1 + i;
  }


  return -1;
}


function getChangedPMRsFromMonthlyChangeReport_(reportSheet) {
  const result = new Map();
  const lastRow = reportSheet.getLastRow();
  const lastCol = reportSheet.getLastColumn();


  if (lastRow < 1 || lastCol < 1) return result;


  const sectionTitles = ["Enrollments", "Disenrollments", "Demographic Changes", "Caseload Changes", "Contact Changes", "Banner Summary Changes", "Banner Changes"];


  let foundSectionLayout = false;


  sectionTitles.forEach(section => {
    const titleRow = findMonthlyChangeSectionTitleRow_(reportSheet, section);
    if (titleRow === -1) return;


    foundSectionLayout = true;


    const headerRow = titleRow + 2;
    const dataStartRow = titleRow + 4;
    const nextTitleRow = findNextMonthlyChangeSectionTitleRow_(reportSheet, titleRow);
    const dataEndRow = nextTitleRow === -1 ? lastRow - 1 : nextTitleRow - 2;


    if (dataEndRow < dataStartRow) return;


    const headers = reportSheet.getRange(headerRow, 1, 1, lastCol)
      .getValues()[0]
      .map(h => String(h || "").trim());
    const headerMap = buildHeaderIndexMap_(headers);
    const pmrIdx = getPMRIndex_(headerMap);


    if (pmrIdx === -1) return;


    const values = reportSheet.getRange(dataStartRow, 1, dataEndRow - dataStartRow + 1, lastCol).getValues();


    values.forEach(row => {
      const pmr = normalizePMR_(row[pmrIdx]);
      if (!pmr) return;


      if (!result.has(pmr)) result.set(pmr, new Set());
      result.get(pmr).add(section);
    });
  });


  if (foundSectionLayout) return result;


  if (lastRow < 5) return result;


  const headers = reportSheet.getRange(4, 1, 1, lastCol)
    .getValues()[0]
    .map(h => String(h || "").trim());
  const headerMap = buildHeaderIndexMap_(headers);


  const sectionIdx = headerMap["Section"];
  const pmrIdx = headerMap["Participant PMR#"];


  if (sectionIdx === undefined || pmrIdx === undefined) return result;


  const values = reportSheet.getRange(5, 1, lastRow - 4, lastCol).getValues();


  values.forEach(row => {
    const pmr = normalizePMR_(row[pmrIdx]);
    const section = String(row[sectionIdx] || "").trim();


    if (!pmr) return;


    if (!result.has(pmr)) result.set(pmr, new Set());
    if (section) result.get(pmr).add(section);
  });


  return result;
}

function runMonthlyChangeValidation() {
  notify_("Standalone Monthly Change validation has been retired. Use Dashboard Quality Report for validation results.");
  return null;
}

function writeDiagnosticReport_(sheetName, title, monthParts, summaryHeaders, summaryRows, detailHeaders, detailRows) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName(sheetName);

  if (!sheet) {
    sheet = ss.insertSheet(sheetName);
  } else {
    sheet.getDataRange().clearContent().clearFormat().breakApart();
  }

  sheet.getRange("A1").setValue(title);
  sheet.getRange("A2").setValue("Date");
  sheet.getRange("B2").setValue(monthParts.firstDay);
  sheet.getRange("C2").setValue("to");
  sheet.getRange("D2").setValue(monthParts.lastDay);

  let row = 4;
  sheet.getRange(row, 1, 1, summaryHeaders.length).setValues([summaryHeaders]);
  row++;

  if (summaryRows && summaryRows.length > 0) {
    sheet.getRange(row, 1, summaryRows.length, summaryHeaders.length).setValues(summaryRows);
    row += summaryRows.length;
  }

  row += 2;
  sheet.getRange(row, 1).setValue("Details");
  row++;
  sheet.getRange(row, 1, 1, detailHeaders.length).setValues([detailHeaders]);
  row++;

  if (detailRows && detailRows.length > 0) {
    sheet.getRange(row, 1, detailRows.length, detailHeaders.length).setValues(detailRows);
  } else {
    sheet.getRange(row, 1).setValue("No issues found.");
  }
}



function runMonthlyUpdate() {
  const monthParts = promptForLockedYearReportMonth_("Monthly Update");
  if (!monthParts) return;
  const messages = [];
  messages.push("Automatic monthly-sheet hiding is disabled in v1.3.5; archive monthly sheets separately.");
  try {
    const reportSheet = buildMonthlyChangeReportForMonth_(monthParts);
    messages.push("Monthly Change Report: " + (reportSheet ? reportSheet.getName() : "No report created"));
  } catch (err) {
    notifyErrorWithTiming_("Monthly Update stopped during Monthly Change Report: " + err.message);
    throw err;
  }
  try {
    const masterSheet = updateMasterListForMonth_(monthParts);
    messages.push("Master List Update: " + (masterSheet ? masterSheet.getName() : "Not completed"));
  } catch (err) {
    notifyErrorWithTiming_("Monthly Update stopped during Update Master List: " + err.message);
    throw err;
  }
  try {
    createIndexSheet();
  } catch (err) {
    Logger.log("Monthly Update final index refresh skipped: " + err.message);
  }
  notify_("Monthly Update complete.\n\n" + messages.join("\n"));
}

function updateMasterList() {
  const monthParts = promptForLockedYearReportMonth_("Update Master List");
  if (!monthParts) return;
  updateMasterListForMonth_(monthParts);
}

function updateMasterListForMonth_(monthParts) {
  if (!monthParts) return null;
  const timing = startRuntimeTiming_("Update Master List", monthParts);
  const hiddenSheetNamesAtStart = captureHiddenSheetNames_();
  let currentMaster = null;
  let rebuiltCount = 0;
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    markRuntimeStep_(timing, "Start");
    const currentDemo = getCurrentDemoPSheet_(monthParts);
    const currentRawData = getCurrentRawDataSheet_(monthParts);
    const previousRawData = getPreviousRawDataSheet_(monthParts);
    const previousMaster = getPreviousMasterListSheet_(monthParts);
    markRuntimeStep_(timing, "Locate monthly source sheets");
    if (!currentDemo) {
      notify_("Current month Demo P was not found. Format Demo P first.");
      markRuntimeStep_(timing, "Stopped - missing current Demo P");
      return null;
    }
    if (!previousMaster) {
      notify_("Previous month Master List was not found. Create the previous month Master List first.");
      markRuntimeStep_(timing, "Stopped - missing previous Master List");
      return null;
    }
    currentMaster = copyPreviousMasterListToCurrentMonth_(previousMaster, monthParts);
    markRuntimeStep_(timing, "Copy previous Master List to current month");
    let reportSheet;
    try {
      reportSheet = getOrBuildMonthlyChangeReport_(ss, monthParts, currentRawData, previousRawData, timing);
      markRuntimeStep_(timing, "Get or build Monthly Change Report");
    } catch (err) {
      markRuntimeStep_(timing, "Stopped - Monthly Change Report error");
      notifyErrorWithTiming_(err.message);
      return null;
    }
    if (reportSheet) {
      rebuiltCount = rebuildChangedPMRsOnExistingMaster_(
        currentDemo,
        currentMaster,
        reportSheet,
        monthParts,
        true,
        timing
      );
      markRuntimeStep_(timing, "Rebuild changed PMRs on copied Master List");
    } else {
      processMasterListFull_(currentMaster, monthParts, null);
      markRuntimeStep_(timing, "No change report rows - full current-month processing");
    }
    finalizeWorkflowAfterCreateOrUpdate_();
    markRuntimeStep_(timing, "Finalize workflow after create/update");
    hidePreviousMonthSheets_(monthParts);
    markRuntimeStep_(timing, "Hide previous month sheets");
    currentMaster.activate();
    removeDisenrolledPMRBlocksFromMasterUsingDemoP_(currentMaster, currentDemo);
    markRuntimeStep_(timing, "Remove disenrolled PMR blocks");
    prepareMasterListSortOrderBeforeFormatting_(currentMaster);
    markRuntimeStep_(timing, "Prepare alphabetical participant ordering before formatting");
    applyFinalMasterListColorAndDisplay_(currentMaster);
    markRuntimeStep_(timing, "Apply final participant coloring and display lock");
    autoHidePreviousMonthSheetsAfterWorkflow_(monthParts);
    markRuntimeStep_(timing, "Auto-hide previous month sheets");
    restorePreviouslyHiddenSheets_(hiddenSheetNamesAtStart, currentMaster);
    markRuntimeStep_(timing, "Restore previously hidden sheets");
    writeRuntimeTimingReport_(timing);
    hideSystemAndTestingSheets_(timing);
    notify_(
      "Update Master List complete.\\n\\n" +
      `New Master List: ${currentMaster.getName()}\\n` +
      `Changed PMRs rebuilt: ${rebuiltCount}\\n` +
      `Runtime: ${formatSeconds_((new Date().getTime() - timing.startMs) / 1000)}\\n` +
      "Previous month sheets hidden."
    );
