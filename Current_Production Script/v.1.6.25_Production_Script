    const additionalIdx = headerMap["Additional Important Information"];
    const additional = additionalIdx === undefined ? "" : String(row[additionalIdx] || "").trim();
    if (additional) parts.push(additional);
    row[notesIdx] = parts.join("\n\n");
  });
}


