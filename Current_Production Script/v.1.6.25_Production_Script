function validateFrameworkTest9Subheaders_(sheet, dashboard, sheetDef, firstTitleRow, colCount) {
  const globals = (dashboard && dashboard.globals) ? dashboard.globals : {};
  const theme = getThemeColorsFromBase_(sheetDef.baseColor, globals);
  const expectedTitleColor = normalizeHex_(theme.level3);
  const expectedSpacerColor = normalizeHex_(theme.level1);
  const expectedHeaderColor = normalizeHex_(theme.level2);
  const results = [];
  let titleRow = firstTitleRow;


  RFF_MONTHLY_CHANGE_SUBSECTIONS.forEach(function(label) {
    const spacerRow = titleRow + 1;
    const headerRow = titleRow + 2;
    const titleColor = normalizeHex_(sheet.getRange(titleRow, 1).getBackground());
    const spacerColor = normalizeHex_(sheet.getRange(spacerRow, 1).getBackground());
    const headerColor = normalizeHex_(sheet.getRange(headerRow, 1).getBackground());
    const spacerHeight = sheet.getRowHeight(spacerRow);
    const headerFontSize = sheet.getRange(headerRow, 1).getFontSize();
    const titleFontSize = sheet.getRange(titleRow, 1).getFontSize();
    const titleFontWeight = sheet.getRange(titleRow, 1).getFontWeight();
    const issues = [];


    if (titleColor !== expectedTitleColor) issues.push("Title color expected " + expectedTitleColor + " found " + titleColor);
    if (titleFontSize !== 14) issues.push("Title font size expected 14 found " + titleFontSize);
    if (titleFontWeight !== "bold") issues.push("Title font weight expected bold found " + titleFontWeight);
    if (spacerColor !== expectedSpacerColor) issues.push("Spacer color expected " + expectedSpacerColor + " found " + spacerColor);
    if (spacerHeight !== 7) issues.push("Spacer row height expected 7 found " + spacerHeight);
    if (headerColor !== expectedHeaderColor) issues.push("Header color expected " + expectedHeaderColor + " found " + headerColor);
    if (headerFontSize !== 8) issues.push("Header font size expected 8 found " + headerFontSize);


    results.push({
      subsection: label,
      status: issues.length === 0 ? "PASS" : "FAIL",
      issues: issues.length === 0 ? "OK" : issues.join("; ")
    });


    titleRow += 3;
  });


  return results;
}

