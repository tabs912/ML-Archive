function archiveMonthlySheetsBySpecs_(parsedMonth, specs, timing) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const archiveSs = SpreadsheetApp.openById(RFF_ARCHIVE_SPREADSHEET_ID);
  const result = { archived: [], skipped: [], failed: [] };
  markFrameworkStep_(timing, "Archive workbook opened", "Archive Spreadsheet ID: " + RFF_ARCHIVE_SPREADSHEET_ID);

  specs.forEach(function(spec) {
    const sheets = findArchiveMonthlyCandidateSheets_(ss, spec.keywords, parsedMonth.monthLabel);
    if (!sheets.length) {
      const message = "No local sheet found for " + spec.label + " " + parsedMonth.monthLabel;
      Logger.log(message);
      markFrameworkStep_(timing, "Archive skipped: " + spec.label, message);
      result.skipped.push(spec.label);
      return;
    }

    sheets.forEach(function(sheet) {
      const sheetName = sheet.getName();
      try {
        copySheetToArchiveAndDeleteLocal_(ss, archiveSs, sheet, sheetName);
        result.archived.push(sheetName);
        markFrameworkStep_(timing, "Archived and removed local sheet: " + sheetName);
      } catch (err) {
        const message = sheetName + ": " + err.message;
        Logger.log("Archive monthly sheet failed: " + message);
        markFrameworkStep_(timing, "Archive failed: " + sheetName, err.message);
        result.failed.push(message);
      }
    });
  });

  markFrameworkStep_(
    timing,
    "Archive monthly sheets complete",
    "Archived: " + result.archived.length + "; Skipped: " + result.skipped.length + "; Failed: " + result.failed.length
  );
  return result;
}

function findArchiveMonthlyCandidateSheets_(ss, keywords, monthLabel) {
  const normalizedMonth = String(monthLabel || "").trim().toLowerCase();
  const keywordList = (keywords || []).map(function(keyword) {
    return String(keyword || "").trim().toLowerCase();
  }).filter(Boolean);
  const matches = [];
  const seen = new Set();

  ss.getSheets().forEach(function(sheet) {
    const name = sheet.getName();
    const lowerName = name.toLowerCase();
    if (lowerName.indexOf("template") !== -1) return;
    if (lowerName.indexOf(normalizedMonth) === -1) return;
    const hasKeyword = keywordList.some(function(keyword) { return lowerName.indexOf(keyword) !== -1; });
    if (!hasKeyword) return;
    if (seen.has(name)) return;
    seen.add(name);
    matches.push(sheet);
  });

  matches.sort(function(a, b) { return a.getName().localeCompare(b.getName()); });
  return matches;
}

function copySheetToArchiveAndDeleteLocal_(ss, archiveSs, sourceSheet, archiveName) {
  if (!sourceSheet) throw new Error("Source sheet is missing.");
  if (ss.getSheets().length <= 1) throw new Error("Cannot delete the final local sheet after archiving.");

  deleteArchiveSheetIfExists_(archiveSs, archiveName);
  const archived = sourceSheet.copyTo(archiveSs);
  archived.setName(archiveName);
  try {
    hideSheetIfNeeded_(archived);
  } catch (err) {
    Logger.log("Archived sheet hide skipped for " + archiveName + ": " + err.message);
  }

  const verified = archiveSs.getSheetByName(archiveName);
  if (!verified) throw new Error("Archive copy verification failed.");

  const fallbackSheet = ss.getSheets().filter(function(sheet) {
    return sheet.getSheetId() !== sourceSheet.getSheetId();
  })[0];
  if (fallbackSheet) ss.setActiveSheet(fallbackSheet);
  ss.deleteSheet(sourceSheet);
  clearMonthlySheetLookupCache_();
  return verified;
}

