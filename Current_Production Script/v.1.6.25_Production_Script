function runDashboardQualityFull() {
  return runFrameworkTimed_("Dashboard Quality Workflow", function(timing) {
    const qualitySheet = ensureDashboardQualityReportSheet_();
    const previousDefer = RFF_DASHBOARD_QUALITY_DEFER_WRITES_;
    RFF_DASHBOARD_QUALITY_DEFER_WRITES_ = true;

    try {
      runDashboardQualitySectionIfDue_(RFF_HEALTH_CHECK_SHEET, "Section H Framework Health Check", runFrameworkHealthCheck, timing);
      runDashboardQualitySectionIfDue_(RFF_PERFORMANCE_SUMMARY_KEY, "Section I Performance Summary", runDashboardQualityPerformanceSummary_, timing);
      runDashboardQualitySectionIfDue_(RFF_MASTER_LIST_HEALTH_KEY, "Section J Master List Health Check", runDashboardQualityMasterListHealthCheck_, timing);
      runDashboardQualitySectionIfDue_(RFF_CP_SYNC_DIAGNOSTICS_KEY, "Section K Care Plan Sync Diagnostics", runDashboardQualityCarePlanSyncDiagnostics_, timing);
      runDashboardQualitySectionIfDue_(RFF_WORKFLOW_SYNC_VERIFICATION_KEY, "Section L Workflow & Synchronization Verification", runDashboardQualityWorkflowSyncVerification_, timing);
    } finally {
      RFF_DASHBOARD_QUALITY_DEFER_WRITES_ = previousDefer;
    }

    const summaryRows = [["Metric", "Value", "Status", "Quality Notes"]];
    buildFrameworkSummaryRows_().forEach(function(row) {
      summaryRows.push(row);
    });

    const signoffRows = [];
    appendCombinedDashboardSignOffRows_(signoffRows);
    while (signoffRows.length && signoffRows[0].length === 1 && String(signoffRows[0][0] || "") === "") {
      signoffRows.shift();
    }

    const now = String(new Date().getTime());
    const props = PropertiesService.getDocumentProperties();
    props.setProperty(RFF_QA_SECTION_PROP_PREFIX + "Summary" + "_LAST_RUN", now);
    props.setProperty(RFF_QA_SECTION_PROP_PREFIX + "Signoff" + "_LAST_RUN", now);

    const sectionWrites = [
      { key: RFF_HEALTH_CHECK_SHEET, title: "SECTION H - FRAMEWORK HEALTH CHECK", rows: getDashboardQualitySectionRows_(RFF_HEALTH_CHECK_SHEET) },
      { key: RFF_PERFORMANCE_SUMMARY_KEY, title: "SECTION I - PERFORMANCE SUMMARY", rows: getDashboardQualitySectionRows_(RFF_PERFORMANCE_SUMMARY_KEY) },
      { key: RFF_MASTER_LIST_HEALTH_KEY, title: "SECTION J - MASTER LIST HEALTH CHECK", rows: getDashboardQualitySectionRows_(RFF_MASTER_LIST_HEALTH_KEY) },
      { key: RFF_CP_SYNC_DIAGNOSTICS_KEY, title: "SECTION K - CARE PLAN SYNC DIAGNOSTICS", rows: getDashboardQualitySectionRows_(RFF_CP_SYNC_DIAGNOSTICS_KEY) },
      { key: RFF_WORKFLOW_SYNC_VERIFICATION_KEY, title: "SECTION L - WORKFLOW & SYNCHRONIZATION VERIFICATION", rows: getDashboardQualitySectionRows_(RFF_WORKFLOW_SYNC_VERIFICATION_KEY) },
      { key: "Summary", title: "SECTION M - SUMMARY", rows: summaryRows },
      { key: "Signoff", title: "SECTION N - SIGNOFF", rows: signoffRows.slice(1) }
    ].map(function(section) {
      return {
        title: section.title,
        rows: buildTimestampedDashboardQualitySectionRows_(section.key, section.rows || [])
      };
    });

    replaceDashboardQualitySectionsRows_(qualitySheet, sectionWrites);
    writeCombinedFrameworkTimingReport_();
    markFrameworkStep_(timing, "Dashboard Quality Sections H-N batch updated");
  });
}

