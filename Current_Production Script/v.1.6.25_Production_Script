  return appendDisenrolledPMRBlocksToExclusion_(rawSheet, rawHeaders, rowsByPMR, monthParts);
}

function moveDisenrolledPMRsFromDemoPToExclusion_(demoSheet, monthParts) {
  const result = { pmrsRemoved: 0, rowsRemoved: 0, rowsCopied: 0 };
  if (!demoSheet) return result;

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let exclusionSheet = ss.getSheetByName(DISENROLLED_EXCLUSION_SHEET);
  if (!exclusionSheet) {
    exclusionSheet = createDisenrolledExclusionSheetFromDashboardTemplate_(ss, monthParts);
  }

  const lastRow = demoSheet.getLastRow();
  const lastCol = demoSheet.getLastColumn();
  if (lastRow < DATA_START_ROW || lastCol < 1) return result;

  const headers = getHeaders_(demoSheet, HEADER_ROW);
  const headerMap = buildHeaderIndexMap_(headers);
  const pmrIdx = getPMRIndex_(headerMap);
  const primaryIdx = headerMap["Primary PMR Row"];
  const disenrollEffectiveIdx = findHeaderIndex_(headerMap, ["Disenrollment Effective Date", "Disenrollment Date", "Date of Death"]);

  if (pmrIdx === -1 || primaryIdx === undefined || disenrollEffectiveIdx === -1) {
    Logger.log("Surgical disenrollment sweep skipped: missing critical schema headers.");
    return result;
  }

  // 1. EXTRACT CURRENT PERSISTENT EXCLUSION REGISTRY
  const existingExclusionData = getDataValues_(exclusionSheet, HEADER_ROW, DATA_START_ROW);
  const existingPmrSet = new Set();
  if (existingExclusionData.headerMap && getPMRIndex_(existingExclusionData.headerMap) !== -1) {
    const exPmrIdx = getPMRIndex_(existingExclusionData.headerMap);
    existingExclusionData.values.forEach(row => {
      const p = normalizePMR_(row[exPmrIdx]);
      if (p) existingPmrSet.add(p);
    });
  }

  const demoDataRange = demoSheet.getRange(DATA_START_ROW, 1, lastRow - DATA_START_ROW + 1, lastCol);
  const values = demoDataRange.getValues();
  const workspaceDisenrolledPMRs = new Set();

  // 2. RUN CURRENT DEMO P WORKSPACE DISENROLLMENT SWEEP
  values.forEach(function(row) {
    const pmr = normalizePMR_(row[pmrIdx]);
    if (!pmr || existingPmrSet.has(pmr)) return;

    // Demo P is a shrinking active workspace: once logged to the persistent Disenrolled Exclusion registry, rows are removed.
    const hasDisenrollmentDate = normalizeCompareValue_(row[disenrollEffectiveIdx]) !== "";
    if (hasDisenrollmentDate) {
      workspaceDisenrolledPMRs.add(pmr);
    }
  });

  if (workspaceDisenrolledPMRs.size === 0) {
    Logger.log("Workspace sweep complete: No new unlinked disenrolled records found on Demo P.");
    return result;
  }

  const keepRows = [];
  let removedCount = 0;
  const rowsToAppendByPMR = new Map();

  // 3. SEGREGATE RETAINED PARTICIPANTS FROM EXCLUDED BLOCKS
  values.forEach(function(row) {
    const pmr = normalizePMR_(row[pmrIdx]);
    if (!pmr || !workspaceDisenrolledPMRs.has(pmr)) {
      keepRows.push(row);
      return;
    }

    if (!rowsToAppendByPMR.has(pmr)) {
      rowsToAppendByPMR.set(pmr, []);
    }
    rowsToAppendByPMR.get(pmr).push(row);
    removedCount++;
  });

  result.pmrsRemoved = workspaceDisenrolledPMRs.size;
  result.rowsRemoved = removedCount;

  // Bulk write new delta rows directly into your database sheet
  result.rowsCopied = appendDisenrolledDeltasToExclusionSheet_(exclusionSheet, headers, rowsToAppendByPMR, monthParts);

  // 4. BULK FLUSH DISENROLLED WORKSPACE LINES
  demoDataRange.clearContent();
  if (keepRows.length > 0) {
    demoSheet.getRange(DATA_START_ROW, 1, keepRows.length, lastCol).setValues(keepRows);
  }

  const newLastRow = DATA_START_ROW + keepRows.length - 1;
  const maxRows = demoSheet.getMaxRows();
  if (maxRows > newLastRow) {
    demoSheet.getRange(newLastRow + 1, 1, maxRows - newLastRow, lastCol).clearContent().breakApart();
  }

  clearSheetRuntimeCachesForSheet_(demoSheet);
  clearSheetRuntimeCachesForSheet_(exclusionSheet);
  return result;
}

function appendDisenrolledDeltasToExclusionSheet_(exclusionSheet, sourceHeaders, rowsToAppendByPMR, monthParts) {
  if (!exclusionSheet || !rowsToAppendByPMR || rowsToAppendByPMR.size === 0) return 0;

  const dashboard = loadDashboardConfig_();
  const exclusionHeaders = getHeadersForSheetType_(dashboard, SHEET_TYPE.DISENROLLED_EXCLUSION);
  const sourceHeaderMap = buildHeaderIndexMap_(sourceHeaders || []);
  const sourcePMRIdx = getPMRIndex_(sourceHeaderMap);
  const exclusionHeaderMap = buildHeaderIndexMap_(exclusionHeaders);
  const exclusionPMRIdx = getPMRIndex_(exclusionHeaderMap);
  const exclusionDateIdx = findHeaderIndex_(exclusionHeaderMap, ["Disenrollment Effective Date", "Disenrollment Date", "Date of Death"]);

  const sourceIndexes = exclusionHeaders.map(function(header) {
    return Object.prototype.hasOwnProperty.call(sourceHeaderMap, header) ? sourceHeaderMap[header] : -1;
  });

  const appendPayload = [];
  rowsToAppendByPMR.forEach(function(rows) {
    (rows || []).forEach(function(sourceRow) {
      if (!sourceRow) return;

      const output = sourceIndexes.map(function(sourceIdx) {
        return sourceIdx === -1 ? "" : sourceRow[sourceIdx];
      });

      if (exclusionPMRIdx >= 0 && sourcePMRIdx >= 0 && !normalizePMR_(output[exclusionPMRIdx])) {
        output[exclusionPMRIdx] = sourceRow[sourcePMRIdx];
      }
      appendPayload.push(output);
    });
  });

  if (appendPayload.length === 0) return 0;

  if (exclusionDateIdx !== -1) {
    appendPayload.sort(function(a, b) {
      const dateA = a[exclusionDateIdx] ? new Date(a[exclusionDateIdx]) : new Date(0);
      const dateB = b[exclusionDateIdx] ? new Date(b[exclusionDateIdx]) : new Date(0);
      return dateB - dateA;
    });
  }

  const insertStartRow = Math.max(exclusionSheet.getLastRow() + 1, DATA_START_ROW);
  const width = Math.max(exclusionHeaders.length, 1);

  if (exclusionSheet.getMaxColumns() < width) {
    exclusionSheet.insertColumnsAfter(exclusionSheet.getMaxColumns(), width - exclusionSheet.getMaxColumns());
  }

  const currentMaxRows = exclusionSheet.getMaxRows();
  if (currentMaxRows < insertStartRow + appendPayload.length - 1) {
    exclusionSheet.insertRowsAfter(currentMaxRows, (insertStartRow + appendPayload.length - 1) - currentMaxRows);
  }

  const targetRange = exclusionSheet.getRange(insertStartRow, 1, appendPayload.length, width);
  targetRange.setValues(appendPayload);

  try {
    exclusionSheet.getRange(DATA_START_ROW, 1, 1, width)
      .copyTo(targetRange, SpreadsheetApp.CopyPasteType.PASTE_FORMAT, false);
  } catch (err) {
    Logger.log("Incremental format brush extension skipped: " + err.message);
  }

  lockFinalOutputRowHeights_(exclusionSheet, "Disenrolled Exclusion");
  clearSheetRuntimeCachesForSheet_(exclusionSheet);
  return appendPayload.length;
}

function appendDisenrolledPMRBlocksToExclusion_(sourceSheet, sourceHeaders, rowsByPMR, monthParts) {
  if (!rowsByPMR || rowsByPMR.size === 0) return 0;

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let exclusionSheet = ss.getSheetByName(DISENROLLED_EXCLUSION_SHEET);
  if (!exclusionSheet) {
    exclusionSheet = createDisenrolledExclusionSheetFromDashboardTemplate_(ss, monthParts);
  }

  return appendDisenrolledDeltasToExclusionSheet_(exclusionSheet, sourceHeaders, rowsByPMR, monthParts);
}

function createDisenrolledExclusionSheetFromDashboardTemplate_(ss, monthParts) {
  ss = ss || SpreadsheetApp.getActiveSpreadsheet();
  const existing = ss.getSheetByName(DISENROLLED_EXCLUSION_SHEET);
  if (existing) return existing;

  const dashboard = loadDashboardConfig_();
  const sheetDef = getSheetDefinitionByType_(dashboard, SHEET_TYPE.DISENROLLED_EXCLUSION);
  const headers = getHeadersForSheetType_(dashboard, SHEET_TYPE.DISENROLLED_EXCLUSION);
  const template = sheetDef && sheetDef.templateName ? ss.getSheetByName(sheetDef.templateName) : null;
  let sheet;

  if (template) {
    sheet = template.copyTo(ss);
    sheet.showSheet();
    setUniqueSheetName_(sheet, DISENROLLED_EXCLUSION_SHEET);
  } else {
    sheet = ss.insertSheet(DISENROLLED_EXCLUSION_SHEET);
    const width = Math.max(headers.length, 1);
    resizeSheetGrid_(sheet, Math.max(resolveTemplateRowCount_(sheetDef, dashboard.globals), 25), width);
    const startDate = monthParts && monthParts.firstDay ? monthParts.firstDay : getTodayLocalDate_();
    const endDate = monthParts && monthParts.lastDay ? monthParts.lastDay : startDate;
    sheet.getRange("A1").setValue(DISENROLLED_EXCLUSION_SHEET);
    sheet.getRange("A2").setValue("Date");
    sheet.getRange("B2").setValue(startDate);
    sheet.getRange("C2").setValue("to");
    sheet.getRange("D2").setValue(endDate);
    if (headers.length) sheet.getRange(HEADER_ROW, 1, 1, headers.length).setValues([headers]);
    applyDashboardTemplateFormattingToActiveReportSheet_(sheet, dashboard, sheetDef, headers, getBehaviorForSheetType_(dashboard, SHEET_TYPE.DISENROLLED_EXCLUSION), monthParts, monthParts && monthParts.lastDay, "Initialized without template", null);
    Logger.log("Template layer missing for Disenrolled Exclusion; initialized persistent sheet from dashboard schema.");
  }

  const startDate = monthParts && monthParts.firstDay ? monthParts.firstDay : getTodayLocalDate_();
  const endDate = monthParts && monthParts.lastDay ? monthParts.lastDay : startDate;
  sheet.getRange("A1").setValue(DISENROLLED_EXCLUSION_SHEET);
  sheet.getRange("A2").setValue("Date");
  sheet.getRange("B2").setValue(startDate);
  sheet.getRange("C2").setValue("to");
  sheet.getRange("D2").setValue(endDate);
  clearSheetRuntimeCachesForSheet_(sheet);
  return sheet;
}

function loadDisenrolledExclusionPMRsForPart3_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(DISENROLLED_EXCLUSION_SHEET);
  const pmrs = new Set();
  if (!sheet || sheet.getLastRow() < DATA_START_ROW) return pmrs;
  const lastCol = sheet.getLastColumn();
  const headers = sheet.getRange(HEADER_ROW, 1, 1, lastCol)
    .getValues()[0]
    .map(h => String(h || "").trim());
  const headerMap = buildHeaderIndexMap_(headers);
  const pmrIdx = getPMRIndex_(headerMap);
  if (pmrIdx === -1) return pmrs;
  const values = sheet.getRange(DATA_START_ROW, 1, sheet.getLastRow() - DATA_START_ROW + 1, lastCol).getValues();
  values.forEach(row => {
    const pmr = normalizePMR_(row[pmrIdx]);
    if (pmr) pmrs.add(pmr);
  });
  return pmrs;
}

function removeDisenrolledPMRBlocksFromMasterUsingDemoP_(masterSheet, demoSheet) {
  if (!masterSheet || !demoSheet) return 0;
  const demoHeaders = getHeaders_(demoSheet, HEADER_ROW);
  const demoHeaderMap = buildHeaderIndexMap_(demoHeaders);
  const demoLastRow = demoSheet.getLastRow();
  const demoLastCol = demoSheet.getLastColumn();
  if (demoLastRow < DATA_START_ROW || demoLastCol < 1) return 0;
  const demoValues = demoSheet.getRange(DATA_START_ROW, 1, demoLastRow - DATA_START_ROW + 1, demoLastCol).getValues();
  const disenrolledPMRs = buildDisenrolledPMRSetFromDemoPValues_(demoValues, demoHeaderMap);
  const exclusionPMRs = loadDisenrolledExclusionPMRsForPart3_();
  exclusionPMRs.forEach(pmr => disenrolledPMRs.add(pmr));
  if (disenrolledPMRs.size === 0) return 0;
  const masterHeaders = getHeaders_(masterSheet, HEADER_ROW);
  const masterHeaderMap = buildHeaderIndexMap_(masterHeaders);
  const masterPMRIdx = getPMRIndex_(masterHeaderMap);
  if (masterPMRIdx === -1) return 0;
  const masterLastRow = masterSheet.getLastRow();
  const masterLastCol = masterSheet.getLastColumn();
  if (masterLastRow < DATA_START_ROW || masterLastCol < 1) return 0;
  const range = masterSheet.getRange(DATA_START_ROW, 1, masterLastRow - DATA_START_ROW + 1, masterLastCol);
  const values = range.getValues();
  const keepRows = [];
  let removed = 0;
  values.forEach(row => {
    const pmr = normalizePMR_(row[masterPMRIdx]);
    if (pmr && disenrolledPMRs.has(pmr)) {
      removed++;
      return;
    }
    keepRows.push(row);
  });
  if (removed === 0) return 0;
  range.clearContent();
