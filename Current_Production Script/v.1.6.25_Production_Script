function getAllUniqueHeaders_() {
  const headerSets = getDefaultHeaderSets_();
  const seen = {};
  const output = [];


  Object.keys(headerSets).forEach(function(sheetType) {
    headerSets[sheetType].forEach(function(item) {
      const header = normalizeHeader_(item.header);
      if (!header || seen[header]) return;
      seen[header] = true;
      output.push(header);
    });
  });


  return output;
}

