function createDisenrolledList() {
  return runFrameworkTimed_("Create Disenrolled List", function(timing) {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const monthParts = promptForLockedYearReportMonth_("Create Disenrolled List");
    if (!monthParts) return null;

    let demoSheet = ss.getSheetByName(SHEET_TYPE.DEMO_P);
    if (!demoSheet) {
      demoSheet = getCurrentDemoPSheet_(monthParts);
    }
    if (!demoSheet) {
      throw new Error("Demo P sheet was not found. Please execute Build Demo P before compiling the Disenrolled Exclusion List.");
    }
    markFrameworkStep_(timing, "Locate ongoing Demo P sheet: " + demoSheet.getName());

    let exclusionSheet = ss.getSheetByName(DISENROLLED_EXCLUSION_SHEET);
    if (!exclusionSheet) {
      exclusionSheet = createDisenrolledExclusionSheetFromDashboardTemplate_(ss, monthParts);
      markFrameworkStep_(timing, "Persistent Disenrolled Exclusion sheet initialized");
    }

    const result = moveDisenrolledPMRsFromDemoPToExclusion_(demoSheet, monthParts);
    markFrameworkStep_(timing, "Copy disenrolled primary records and remove rows: " + result.rowsCopied + " copied, " + result.rowsRemoved + " removed");
    setLastRawDataDisenrolledBuildResult_(result);
    notify_("Disenrolled Exclusion updated. PMRs identified: " + result.pmrsRemoved + "; primary rows written: " + result.rowsCopied + "; Demo P rows removed: " + result.rowsRemoved + ".");
    return result;
  });
}

function processBlankContactSummariesOnDemoP_(demoSheet, timing) {
  const data = getDataValues_(demoSheet, HEADER_ROW, DATA_START_ROW);
  if (!data.values.length) return 0;
  const summaryIdx = data.headerMap["Contact - Summary"];
  if (summaryIdx === undefined) return 0;
