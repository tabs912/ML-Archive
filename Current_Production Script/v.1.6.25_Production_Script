function runFrameworkTest6DateFormattingCore_(dashboard, timing, options) {
  const activeDashboard = dashboard || loadDashboardConfig_();
  const results = [];

  activeDashboard.sheetDefinitions.forEach(function(sheetDef) {
    const templateResults = testDateFormattingForTemplate_(activeDashboard, sheetDef);
    results.push.apply(results, templateResults);
    markFrameworkStep_(timing, "Checked date formats: " + sheetDef.templateName);
  });

  writeFrameworkTest6DateFormatReport_(results, options);
